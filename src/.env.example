# Copy this file to one of these locations and fill in your values:
#   1. .env
#   2. .env.local
#   3. local-data\.env
#   4. local-data\.env.local
#
# Precedence:
#   process environment > .env.local > .env > saved UI settings
#
# Default data directory:
#   - npm start: <this folder>\local-data
#   - packaged app: <folder beside the exe>\local-data
#
# Optional storage override:
# STANDUPSCRIBE_DATA_DIR="C:\path\to\standupscribe-data"
#
# Optional console logging override:
# STANDUPSCRIBE_LOG_TO_STDOUT="1"

# Azure OpenAI realtime configuration for StandupScribe.
AZURE_OPENAI_BASE_URL="https://your-resource.openai.azure.com/openai/v1"
AZURE_OPENAI_DEPLOYMENT_NAME="gpt-realtime-2"
AZURE_OPENAI_TRANSCRIPTION_DEPLOYMENT_NAME="gpt-realtime-whisper"
# Optional preview API version override when using Azure resource endpoints.
# AZURE_OPENAI_API_VERSION="2025-04-01-preview"

# Option A: API key authentication.
AZURE_OPENAI_API_KEY="<your-azure-openai-api-key>"

# Option B: Azure AD service principal authentication.
AZURE_TENANT_ID="<your-tenant-id>"
AZURE_CLIENT_ID="<your-client-id>"
AZURE_CLIENT_SECRET="<your-client-secret>"

# Azure DevOps integration is configured via the Settings UI.
